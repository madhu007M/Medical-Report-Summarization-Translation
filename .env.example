# Copy this file to .env and fill in your credentials
# cp .env.example .env

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
# Default: SQLite (no setup required)
# DATABASE_URL=sqlite:///./medical_platform.db

# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/medical_platform

# ─────────────────────────────────────────────────────────────────────────────
# AI Models
# ─────────────────────────────────────────────────────────────────────────────
# HuggingFace summarization model (downloaded on first use)
# SUMMARIZATION_MODEL=facebook/bart-large-cnn

# ─────────────────────────────────────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────────────────────────────────────
# CHANGE THIS IN PRODUCTION — used to sign JWT tokens
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ─────────────────────────────────────────────────────────────────────────────
# Twilio (SMS / WhatsApp)
# ─────────────────────────────────────────────────────────────────────────────
# Get these from https://console.twilio.com/
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─────────────────────────────────────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────────────────────────────────────
# URL that the Streamlit frontend uses to reach the FastAPI backend
# API_BASE_URL=http://localhost:8000
