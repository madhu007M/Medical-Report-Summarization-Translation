# Tesseract OCR Configuration
# Windows: Install from https://github.com/tesseract-ocr/tesseract/wiki/Downloads
# Linux: sudo apt-get install tesseract-ocr
# macOS: brew install tesseract
TESSERACT_CMD_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Database (SQLite by default)
DATABASE_URL=sqlite:///./health_platform.db

# Summarization Model
SUMMARIZER_MODEL=facebook/bart-large-cnn

# Multilingual Translation Models (Helsinki-NLP Opus MT models)
# Hindi, Kannada, Tamil, Telugu, Marathi, Bengali
TRANSLATOR_HI_MODEL=Helsinki-NLP/opus-mt-en-hi
TRANSLATOR_KN_MODEL=Helsinki-NLP/opus-mt-en-mul
TRANSLATOR_TA_MODEL=Helsinki-NLP/opus-mt-en-tam
TRANSLATOR_TE_MODEL=Helsinki-NLP/opus-mt-en-mul
TRANSLATOR_MR_MODEL=Helsinki-NLP/opus-mt-en-mul
TRANSLATOR_BN_MODEL=Helsinki-NLP/opus-mt-en-bn

# Text-to-Speech
TTS_PROVIDER=gtts

# Twilio Credentials (for SMS/WhatsApp messaging)
# OPTIONAL: Platform works in test mode without these credentials
# Test mode simulates messaging without sending real messages
#
# To enable real messaging:
# 1. Sign up at https://www.twilio.com/try-twilio
# 2. Get credentials from Twilio Console
# 3. Replace values below with your actual credentials
# See TWILIO_SETUP_GUIDE.md for detailed instructions
#
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# Backend URL (for frontend API calls)
BACKEND_URL=http://localhost:8000

# Outbreak Detection Threshold
OUTBREAK_CLUSTER_THRESHOLD=5
